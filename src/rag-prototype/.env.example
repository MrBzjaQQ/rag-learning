# Database Configuration
DATABASE_URL=postgresql://raguser:ragpassword@postgres:5432/ragdb

# OpenAI API Configuration (for LLM)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=http://host.docker.internal:8033/v1

# OpenAI API Configuration (for embeddings)
OPENAI_API_KEY_EMBEDDINGS=your_openai_api_key_here
OPENAI_BASE_URL_EMBEDDINGS=http://host.docker.internal:8034/v1

# Llama.cpp Configuration
LLAMA_CPP_MODEL_PATH=/path/to/model.gguf

# Application Settings
APP_NAME="RAG Prototype"
DEBUG=False